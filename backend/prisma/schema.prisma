generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url = env("DATABASE_URL")
}

model Aviso {
  id          Int    @id @default(autoincrement())
  title       String
  description String
  type        String
}

model Usuario {
  id Int @id @default(autoincrement())
  nome String
  email String @unique
  senha String
  createdAt DateTime @default(now())
model Edital {
  id          Int    @id @default(autoincrement())
  titulo      String
  descricao   String
  data        String
  status      String
  link        String
}